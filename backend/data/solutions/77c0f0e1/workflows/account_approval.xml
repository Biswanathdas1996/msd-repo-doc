<?xml version="1.0" encoding="utf-8"?>
<Workflow Name="Account Approval Workflow" PrimaryEntity="Account" Trigger="Update">
  <Steps>
    <Step Name="Validate account data"/>
    <Step Name="Check approval threshold"/>
    <Step Name="Route to manager for approval"/>
    <Step Name="Send approval notification email"/>
    <Step Name="Update account status"/>
  </Steps>
  <Conditions>
    <Condition Name="Revenue exceeds $100,000"/>
    <Condition Name="Account status is Active"/>
  </Conditions>
</Workflow>