<?xml version="1.0" encoding="utf-8"?>
<Entity Name="Opportunity">
  <DisplayName>Opportunity</DisplayName>
  <Attributes>
    <Attribute Name="name" Type="String" Required="true">
      <DisplayName>Opportunity Name</DisplayName>
    </Attribute>
    <Attribute Name="estimatedvalue" Type="Money">
      <DisplayName>Estimated Value</DisplayName>
    </Attribute>
    <Attribute Name="closeprobability" Type="Integer">
      <DisplayName>Close Probability</DisplayName>
    </Attribute>
    <Attribute Name="customerid" Type="Lookup" Required="true">
      <DisplayName>Customer</DisplayName>
    </Attribute>
    <Attribute Name="statuscode" Type="Picklist" Required="true">
      <DisplayName>Status</DisplayName>
    </Attribute>
    <Attribute Name="estimatedclosedate" Type="DateTime">
      <DisplayName>Estimated Close Date</DisplayName>
    </Attribute>
  </Attributes>
</Entity>