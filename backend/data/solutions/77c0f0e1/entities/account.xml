      <DisplayName>Account Name</DisplayName>
    </Attribute>
    <Attribute Name="emailaddress1" Type="String" Required="true">
      <DisplayName>Email Address</DisplayName>
    </Attribute>
    <Attribute Name="telephone1" Type="String">
      <DisplayName>Phone Number</DisplayName>
    </Attribute>
