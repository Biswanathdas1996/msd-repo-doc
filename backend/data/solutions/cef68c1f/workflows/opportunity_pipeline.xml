<?xml version="1.0" encoding="utf-8"?>
<Workflow Name="Opportunity Pipeline Process" PrimaryEntity="Opportunity" Trigger="Create">
  <Steps>
    <Step Name="Qualify lead source"/>
    <Step Name="Assign sales representative"/>
    <Step Name="Create follow-up task"/>
    <Step Name="Send welcome email to customer"/>
    <Step Name="Schedule initial meeting"/>
  </Steps>
  <Conditions>
    <Condition Name="Estimated value above minimum"/>
    <Condition Name="Valid customer reference"/>
  </Conditions>
</Workflow>