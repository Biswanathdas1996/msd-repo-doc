# ──────────────────────────────────────────────
# Backend - Python FastAPI
# ──────────────────────────────────────────────
PYTHON_API_PORT=5001

# PwC Gen AI Configuration (required for AI documentation generation)
PWC_GENAI_ENDPOINT_URL=https://genai-sharedservice-americas.pwc.com/completions
PWC_GENAI_API_KEY=your_pwc_genai_api_key_here
PWC_GENAI_BEARER_TOKEN=your_pwc_genai_bearer_token_here
PWC_GENAI_MODEL=vertex_ai.gemini-2.5-flash-image

# ──────────────────────────────────────────────
# Claude Code CLI (required for Advanced Docs feature)
# Get your key from: https://console.anthropic.com/settings/keys
# Standard solution documentation uses PWC GenAI above — not this CLI. Advanced Docs only.
# If the API logs "CLI not found" but `claude` works in your terminal, PATH may omit npm's
# global bin; set CLAUDE_CODE_CLI to claude.cmd (Windows) or rely on %APPDATA%\npm fallback.
#
# Advanced Docs — Technical Specs: auto = PWC when PWC_GENAI_ENDPOINT_URL is set, else Claude CLI.
# ADVANCED_TECH_SPECS_PROVIDER=auto
# ADVANCED_TECH_SPECS_PROVIDER=pwc
# ADVANCED_TECH_SPECS_PROVIDER=claude
# PWC_TECH_SPECS_MAX_INPUT_CHARS=72000
# PWC_TECH_SPECS_MAX_OUTPUT_TOKENS=8192
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# CLAUDE_CODE_CLI=C:/Users/You/AppData/Roaming/npm/claude.cmd

# ──────────────────────────────────────────────
# Frontend - Vite (doc-generator)
# ──────────────────────────────────────────────
PORT=5173
BASE_PATH=/

# ──────────────────────────────────────────────
# API Server - Express
# ──────────────────────────────────────────────
NODE_ENV=development

# ──────────────────────────────────────────────
# Database (optional - only needed if using PostgreSQL features)
# ──────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/knowledge_graph_docs
